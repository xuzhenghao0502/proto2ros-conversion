    import cv2
except ImportError:
    cv2 = None
try:
    from PIL import Image as PILImage
except ImportError:
    PILImage = None
try:
    import av
except ImportError:
    av = None

# PyAV 10+ uses av.error.FFmpegError; older wheels exposed av.AVError.
if av is not None:
    try:
        from av.error import FFmpegError as _PyAVCodecError
    except ImportError:
        _PyAVCodecError = getattr(av, 'AVError', OSError)
else:
    _PyAVCodecError = OSError


def _proto_generated_class(pool: DescriptorPool, fqn: str) -> Type:
    """Resolve the concrete protobuf class emitted by protoc (matches proto2ros @convert.register types)."""
    desc = pool.FindMessageTypeByName(fqn)
    path = desc.file.name.replace('\\', '/')
    if not path.endswith('.proto'):
        raise ValueError(f'unexpected proto path {path!r}')
    module = path[:-6].replace('/', '.') + '_pb2'
    mod = importlib.import_module(module)
    return getattr(mod, desc.name)


def _ros_msg_type_string(msg_cls) -> str:
    return f'gpal_proto_bridge/msg/{msg_cls.__name__}'


def _ros_msg_class(short_name: str):
    mod = importlib.import_module('gpal_proto_bridge.msg')
    return getattr(mod, short_name)


def _short_name_from_proto_fqn(fqn: str) -> str:
    return fqn.rsplit('.', 1)[-1]


def _sanitize_topic(url: str) -> str:
    s = url.replace('://', '/').replace('?', '_').replace('&', '_').replace('=', '_')
    s = re.sub(r'[^0-9A-Za-z/_-]+', '_', s)
    s = re.sub(r'_+', '_', s).strip('_')
    return '/ekart/' + s.lstrip('/')


def _normalize_topic_key(name: str) -> str:
    """Canonical form for comparing user --only-topic with sanitized recorder topics."""
    s = name.strip().replace('//', '/')
    if not s.startswith('/'):
        s = '/' + s
    return s.rstrip('/') or '/'


def _frame_id_from_url(url: str) -> str:
    path = url.split('?', 1)[0].strip()
    seg = path.rstrip('/').split('/')[-1]
    return seg if seg else 'sensor'


def _time_from_stamp_ns(stamp_ns: int) -> Time:
    t = Time()
    t.sec = int(stamp_ns // 1_000_000_000)
    t.nanosec = int(stamp_ns % 1_000_000_000)
    return t


def _header(stamp_ns: int, frame_id: str) -> Header:
    h = Header()
    h.stamp = _time_from_stamp_ns(stamp_ns)
    h.frame_id = frame_id
    return h


# --- EkaRT URL serializer strings (EkaRT_Urls.ser) → how we interpret each row blob ---
EKA_SER_CAMERA_FRAME = 'eka::rt::msg::CameraFrame'
EKA_SER_POINT_CLOUD = _ezpc.EKA_SER_POINT_CLOUD


def _classify_eka_ser(ser: str) -> str:
    """Return a short label for logging / dispatch; matches DB ``ser`` column."""
    if ser == EKA_SER_CAMERA_FRAME:
        return 'camera_frame'
    if ser == EKA_SER_POINT_CLOUD:
        return 'point_cloud'
    if ser.startswith('gpal.proto.'):
        return 'gpal_proto'
    return 'unknown'


def _eka_pointcloud_to_pointcloud2(blob: bytes, stamp_ns: int, frame_id: str) -> Optional[PointCloud2]:
    """GPAL zerocopy ``eka::rt::msg::PointCloud`` → ``sensor_msgs/PointCloud2`` (via ``ekart_zerocopy_pointcloud``)."""
    parsed = _ezpc.parse_zerocopy_pointcloud_blob(blob)
    if parsed is None:
        return None
    return _ezpc.pointcloud2_from_parsed(parsed, _header(stamp_ns, frame_id))


def _decode_jpeg_to_bgr(data: bytes) -> Optional[np.ndarray]:
    if cv2 is not None:
        arr = np.frombuffer(data, dtype=np.uint8)
        bgr = cv2.imdecode(arr, cv2.IMREAD_COLOR)
        return bgr
    if PILImage is not None:
        im = PILImage.open(BytesIO(data)).convert('RGB')
        rgb = np.asarray(im)
        return np.ascontiguousarray(rgb[:, :, ::-1])
    return None


# gpal.proto.CameraFrame.Type (subset + numeric fall-through)
_CAM_BGR_PACKED = 11
_CAM_RGB_PACKED = 13
_CAM_NV12 = 4
_CAM_YUYV = 5
_CAM_JPEG = 21
_CAM_H264 = 22
_CAM_H265 = 23


def _bmp_bytes_to_bgr(buf: bytes) -> Optional[np.ndarray]:
    if not buf:
        return None
    if cv2 is not None:
        return cv2.imdecode(np.frombuffer(buf, dtype=np.uint8), cv2.IMREAD_COLOR)
    if PILImage is not None:
        rgb = np.asarray(PILImage.open(BytesIO(buf)).convert('RGB'))
        return np.ascontiguousarray(rgb[:, :, ::-1])
    return None


def _ffmpeg_h26x_first_frame_bgr(data: bytes, codec: str) -> Optional[np.ndarray]:
    """Decode one access unit (Annex B) to BGR using ffmpeg → BMP pipe (stateless)."""
    ff = shutil.which('ffmpeg')
    if not ff or not data:
        return None
    fmt = 'h264' if codec == 'h264' else 'hevc'
    cmd = [
        ff,
        '-hide_banner',
        '-loglevel',
        'error',
        '-f',
        fmt,
        '-i',
        'pipe:0',
        '-frames:v',
        '1',
        '-f',
        'image2pipe',
        '-vcodec',
        'bmp',
        'pipe:1',
    ]
    try:
        proc = subprocess.run(cmd, input=data, capture_output=True, timeout=120, check=False)
    except (OSError, subprocess.SubprocessError):
        proc = None
    if proc and proc.returncode == 0 and proc.stdout:
        bgr = _bmp_bytes_to_bgr(proc.stdout)
        if bgr is not None:
            return bgr
    # Some devices use length-prefixed NALs; let ffmpeg probe instead of forcing raw demuxer.
    cmd2 = [
        ff,
        '-hide_banner',
        '-loglevel',
        'error',
        '-i',
        'pipe:0',
        '-frames:v',
        '1',
        '-f',
        'image2pipe',
        '-vcodec',
        'bmp',
        'pipe:1',
    ]
    try:
        proc2 = subprocess.run(cmd2, input=data, capture_output=True, timeout=120, check=False)
    except (OSError, subprocess.SubprocessError):
        return None
    if proc2.returncode != 0 or not proc2.stdout:
        return None
    return _bmp_bytes_to_bgr(proc2.stdout)


class _PyAVTopicDecoder:
    """Stateful H.264 / HEVC decoder per topic (handles P/B frames across DB rows)."""

    __slots__ = ('codec_name', '_ctx')

    def __init__(self, codec_name: str) -> None:
        if av is None:
            raise RuntimeError('PyAV not available')
        self.codec_name = codec_name
        self._ctx = av.codec.CodecContext.create(codec_name, 'r')

    def feed(self, data: bytes) -> Optional[np.ndarray]:
        if not data:
            return None
        last: Optional[np.ndarray] = None
        try:
            for frame in self._ctx.decode(av.Packet(data)):
                last = frame.to_ndarray(format='bgr24')
        except _PyAVCodecError:
            return last
        return last


def _sensor_image_from_camera_proto(
    cam,
    stamp_ns: int,
    frame_id: str,
    *,
    topic: str,
    h26x_decoders: Dict[str, _PyAVTopicDecoder],
) -> Optional[Image]:
    h, w = int(cam.height), int(cam.width)
    typ = int(cam.type)
    data = bytes(cam.data)
    msg = Image()
    msg.header = _header(stamp_ns, frame_id)

    # Payload is JPEG (SOI) even when header `type` says something else (e.g. mis-tagged as H264).
    if len(data) >= 3 and data[:3] == b'\xff\xd8\xff':
        bgr = _decode_jpeg_to_bgr(data)
        if bgr is None:
            print(
                '[warn] CameraFrame: JPEG (FF D8 FF) payload but decode failed (opencv/pillow?)',
                file=sys.stderr,
            )
            return None
        hi, wi = bgr.shape[:2]
        msg.height, msg.width = hi, wi
        msg.encoding = 'bgr8'
        msg.is_bigendian = 0
        msg.step = wi * 3
        msg.data = bgr.tobytes()
        return msg

    if typ == _CAM_JPEG:
        bgr = _decode_jpeg_to_bgr(data)
        if bgr is None:
            print('[warn] CameraFrame: JPEG decode needs python3-opencv or pillow', file=sys.stderr)
            return None
        hi, wi = bgr.shape[:2]
        msg.height, msg.width = hi, wi
        msg.encoding = 'bgr8'
        msg.is_bigendian = 0
        msg.step = wi * 3
        msg.data = bgr.tobytes()
        return msg

    if typ == _CAM_BGR_PACKED:
        if h <= 0 or w <= 0 or len(data) < h * w * 3:
            print('[warn] CameraFrame: invalid BGR packed size', file=sys.stderr)
            return None
        msg.height, msg.width = h, w
        msg.encoding = 'bgr8'
        msg.is_bigendian = 0
        msg.step = w * 3
        msg.data = data[: h * w * 3]
        return msg

    if typ == _CAM_RGB_PACKED:
        if h <= 0 or w <= 0 or len(data) < h * w * 3:
            print('[warn] CameraFrame: invalid RGB packed size', file=sys.stderr)
            return None
        msg.height, msg.width = h, w
        msg.encoding = 'rgb8'
        msg.is_bigendian = 0
        msg.step = w * 3
        msg.data = data[: h * w * 3]
        return msg

    if typ in (_CAM_H264, _CAM_H265):
        if not data:
            print(
                '[warn] CameraFrame: empty H264/HEVC payload (could not find JPEG / Annex B start in blob)',
                file=sys.stderr,
            )
            return None
        codec = 'h264' if typ == _CAM_H264 else 'hevc'
        bgr: Optional[np.ndarray] = None
        if av is not None:
            dec = h26x_decoders.get(topic)
            if dec is None or dec.codec_name != codec:
                dec = _PyAVTopicDecoder(codec)
                h26x_decoders[topic] = dec
            bgr = dec.feed(data)
        if bgr is None:
            bgr = _ffmpeg_h26x_first_frame_bgr(data, codec)
        if bgr is None:
            print(
                '[warn] CameraFrame: H264/H265 decode failed for '
                f'{topic!r} (install `ffmpeg`; for P-frames also: `pip install av`)',
                file=sys.stderr,
            )
            return None
        hi, wi = bgr.shape[:2]
        msg.height, msg.width = int(hi), int(wi)
        msg.encoding = 'bgr8'
        msg.is_bigendian = 0
        msg.step = int(wi) * 3
        msg.data = bgr.tobytes()
        return msg

    if cv2 is None:
        print(f'[warn] CameraFrame: type {typ} needs python3-opencv; install or use JPEG/BGR/RGB only', file=sys.stderr)
        return None

    if typ == _CAM_NV12:
        need = int(h * w * 3 / 2)
        if len(data) < need:
            print('[warn] CameraFrame: NV12 buffer too small', file=sys.stderr)
            return None
        yuv = np.frombuffer(data[:need], dtype=np.uint8).reshape((h * 3 // 2, w))
        bgr = cv2.cvtColor(yuv, cv2.COLOR_YUV2BGR_NV12)
        msg.height, msg.width = h, w
        msg.encoding = 'bgr8'
        msg.is_bigendian = 0
        msg.step = w * 3
        msg.data = bgr.tobytes()
        return msg

    if typ == _CAM_YUYV:
        need = h * w * 2
        if len(data) < need or w % 2 != 0:
            print('[warn] CameraFrame: YUYV buffer too small or odd width', file=sys.stderr)
            return None
        arr = np.frombuffer(data[:need], dtype=np.uint8).reshape((h, w // 2, 4))
        bgr = cv2.cvtColor(arr, cv2.COLOR_YUV2BGR_YUYV)
        msg.height, msg.width = h, w
        msg.encoding = 'bgr8'
        msg.is_bigendian = 0
        msg.step = w * 3
        msg.data = bgr.tobytes()
        return msg

    print(f'[warn] CameraFrame: unsupported pixel type {typ} for sensor_msgs/Image', file=sys.stderr)
    return None


def _h264_nal_type_ok(first_nal_byte: int) -> bool:
    """H.264: nal_unit_type = first byte & 0x1F (1..23 valid in elementary stream)."""
    t = first_nal_byte & 0x1F
    return 1 <= t <= 23


def _hevc_nal_ok(b0: int, b1: int) -> bool:
    """HEVC: 2-byte NAL header after start code; nal_unit_type = (b0 >> 1) & 0x3F."""
    if (b0 >> 1) & 0x3F == 0:
        return False
    return True


def _find_annex_b_h264(blob: bytes) -> Optional[int]:
    n = len(blob)
    i = 0
    while i < n - 4:
        if blob[i : i + 4] == b'\x00\x00\x00\x01':
            if i + 4 < n and _h264_nal_type_ok(blob[i + 4]):
                return i
        if (
            i + 3 <= n
            and blob[i : i + 3] == b'\x00\x00\x01'
            and (i == 0 or blob[i - 1] != 0)
            and i + 3 < n
            and _h264_nal_type_ok(blob[i + 3])
        ):
            return i
        i += 1
    return None


def _find_annex_b_hevc(blob: bytes) -> Optional[int]:
    n = len(blob)
    i = 0
    while i < n - 5:
        if blob[i : i + 4] == b'\x00\x00\x00\x01':
            if i + 5 < n and _hevc_nal_ok(blob[i + 4], blob[i + 5]):
                return i
        if (
            i + 3 <= n
            and blob[i : i + 3] == b'\x00\x00\x01'
            and (i == 0 or blob[i - 1] != 0)
            and i + 4 < n
            and _hevc_nal_ok(blob[i + 3], blob[i + 4])
        ):
            return i
        i += 1
    return None


def _find_compressed_media_start(blob: bytes, pixel_type: Optional[int] = None) -> Optional[int]:
    """Locate first media byte: JPEG, or Annex B H.264 / HEVC (any NAL), not only SPS/PPS."""
    j = blob.find(b'\xff\xd8\xff')
    if j >= 0:
        return j
    j = blob.find(b'\xff\xdb')
    if j >= 0:
        return j

    if pixel_type == _CAM_H265:
        off = _find_annex_b_hevc(blob)
        if off is not None:
            return off
    if pixel_type in (None, _CAM_H264, _CAM_H265):
        off = _find_annex_b_h264(blob)
        if off is not None:
            return off
    if pixel_type in (None, _CAM_H265):
        off = _find_annex_b_hevc(blob)
        if off is not None:
            return off

    for sig in (
        b'\x00\x00\x00\x01\x67',
        b'\x00\x00\x00\x01\x68',
        b'\x00\x00\x01\x67',
        b'\x00\x00\x01\x68',
    ):
        k = blob.find(sig)
        if k >= 0:
            return k
    return None


def _camera_eka_to_proto(pool: DescriptorPool, blob: bytes):
    u0 = struct.unpack_from('<Q', blob, 0)[0]
    ts = struct.unpack_from('<Q', blob, 8)[0]
    ch, w, h, freq, typ = struct.unpack_from('<IIIII', blob, 24)
    if w > 16384 or h > 16384 or ch > 65535:
        raise ValueError('implausible camera header (width/height/channel)')
    media_off = _find_compressed_media_start(blob, typ)
    if media_off is None:
        media_off = len(blob)
    msg = _proto_generated_class(pool, 'gpal.proto.CameraFrame')()
    msg.header.time_meas = int(ts)
    msg.channel = ch
    msg.width = w
    msg.height = h
    msg.freq = freq
    msg.type = typ
    msg.data = blob[media_off:]
    _ = u0  # layout discriminator reserved for future variants
    return msg


def _proto_fqn_for_url_ser(ser: str) -> Optional[str]:
    if ser.startswith('gpal.proto.'):
        return ser
    if ser == EKA_SER_CAMERA_FRAME:
        return 'gpal.proto.CameraFrame'
    if ser == EKA_SER_POINT_CLOUD:
        return None
    return None


def _load_db2bag_topic_config(path: str) -> Dict[str, Tuple[str, str]]:
    """Load ``topic`` / ``eka_type`` / ``ros_type`` entries; keys are normalized topic names."""
    try:
        import yaml
    except ModuleNotFoundError as exc:
        raise SystemExit(
            'db2bag --config needs PyYAML.\n'
            'Fix: sudo apt install python3-yaml   or   pip install pyyaml\n'
            '(see gpal_proto_bridge package.xml exec_depend python3-yaml).'
        ) from exc

    with open(path, encoding='utf-8') as f:
        doc = yaml.safe_load(f)
    topics = doc.get('topics') if isinstance(doc, dict) else None
    if not isinstance(topics, list):
        raise SystemExit(f'{path}: expected a mapping with key "topics" whose value is a list')

    out: Dict[str, Tuple[str, str]] = {}
    for i, item in enumerate(topics):
        if not isinstance(item, dict):
            raise SystemExit(f'{path}: topics[{i}] must be a mapping')
        t = item.get('topic')
        ek = item.get('eka_type')
        rt = item.get('ros_type')
        if not isinstance(t, str) or not isinstance(ek, str) or not isinstance(rt, str):
            raise SystemExit(
                f'{path}: topics[{i}] needs string fields topic, eka_type, ros_type'
            )
        nt = _normalize_topic_key(t)
        if nt in out:
            raise SystemExit(f'{path}: duplicate topic {t!r}')
        ros_type = rt.strip()
        if '/' not in ros_type:
            raise SystemExit(
                f'{path}: topics[{i}] ros_type must look like pkg/msg/Name, got {ros_type!r}'
            )
        out[nt] = (ek.strip(), ros_type)
    return out


def _load_descriptor_pool() -> DescriptorPool:
    share = get_package_share_directory('gpal_proto_bridge')
    desc_path = os.path.join(share, 'gpal_proto_bridge_messages_gen.desc')
    if not os.path.isfile(desc_path):
        raise FileNotFoundError(
            f'Missing {desc_path}. Build and install gpal_proto_bridge, then source the workspace.'
        )
    with open(desc_path, 'rb') as f:
        fds = FileDescriptorSet.FromString(f.read())
    pool = DescriptorPool()
    for fd in fds.file:
        pool.Add(fd)
    return pool


def _row_timestamp_ns(start_timestamp_ms: int, elapsed: int) -> int:
    # EkaRT: start_timestamp is milliseconds since epoch; elapsed is microseconds from recording start.
    return int(start_timestamp_ms * 1_000_000 + elapsed * 1_000)


def convert_db(
    db_path: str,
    bag_uri: str,
    storage_id: str,
    pool: DescriptorPool,
    topic_prefix: str = '',
    only_topics: Optional[FrozenSet[str]] = None,
    topic_specs: Optional[Dict[str, Tuple[str, str]]] = None,
) -> None:
    conn = sqlite3.connect(db_path)
    start_ms = conn.execute('SELECT start_timestamp FROM EkaRT_Header LIMIT 1').fetchone()[0]

    urls: Dict[int, Tuple[str, str]] = {}
    for uid, url, ser in conn.execute('SELECT id, url, ser FROM EkaRT_Urls').fetchall():
        urls[int(uid)] = (str(url), str(ser))

    writer = rosbag2_py.SequentialWriter()
    writer.open(
        rosbag2_py.StorageOptions(uri=bag_uri, storage_id=storage_id),
        rosbag2_py.ConverterOptions(
            input_serialization_format='cdr',
            output_serialization_format='cdr',
        ),
    )

    topics_added: Dict[str, str] = {}

    def ensure_topic(topic: str, ros_type: str) -> None:
        if topic in topics_added:
            if topics_added[topic] != ros_type:
                raise RuntimeError(f'Topic {topic} reused with different types')
            return
        topics_added[topic] = ros_type
        writer.create_topic(
            rosbag2_py.TopicMetadata(
                name=topic,
                type=ros_type,
                serialization_format='cdr',
                offered_qos_profiles='',
            )
        )

    rows = conn.execute(
        'SELECT elapsed, url, data FROM EkaRT_Datas ORDER BY elapsed, rowid'
    ).fetchall()

    h26x_decoders: Dict[str, _PyAVTopicDecoder] = {}

    for elapsed, url_id, data in rows:
        url_id = int(url_id)
        if url_id not in urls:
            continue
        url, ser = urls[url_id]
        topic = (topic_prefix + _sanitize_topic(url)).replace('//', '/')
        nt = _normalize_topic_key(topic)

        exp_ros: Optional[str] = None
        if topic_specs is not None:
            spec = topic_specs.get(nt)
            if spec is None:
                continue
            exp_eka, exp_ros = spec
            if ser != exp_eka:
                print(
                    f'[skip] topic {topic!r}: config eka_type {exp_eka!r} != db ser {ser!r}',
                    file=sys.stderr,
                )
                continue
        if only_topics is not None and nt not in only_topics:
            continue

        ts_ns = _row_timestamp_ns(int(start_ms), int(elapsed))
        blob = data

        row_kind = _classify_eka_ser(ser)

        if row_kind == 'point_cloud':
            ros_t = exp_ros or 'sensor_msgs/msg/PointCloud2'
            if ros_t != 'sensor_msgs/msg/PointCloud2':
                print(
                    f'[skip] topic {topic!r}: eka PointCloud maps to '
                    f'sensor_msgs/msg/PointCloud2, config has {ros_t!r}',
                    file=sys.stderr,
                )
                continue
            ensure_topic(topic, ros_t)
            # Lidar point clouds use a fixed frame for downstream fusion / TF trees.
            pc2 = _eka_pointcloud_to_pointcloud2(blob, ts_ns, 'base_link')
            if pc2 is not None:
                writer.write(topic, serialize_message(pc2), ts_ns)
            continue

        if row_kind == 'camera_frame':
            ros_t = exp_ros or 'sensor_msgs/msg/Image'
            if ros_t != 'sensor_msgs/msg/Image':
                print(
                    f'[skip] topic {topic!r}: eka CameraFrame maps to '
                    f'sensor_msgs/msg/Image, config has {ros_t!r}',
                    file=sys.stderr,
                )
                continue
            ensure_topic(topic, ros_t)
            cam_proto = _camera_eka_to_proto(pool, blob)
            fid = _frame_id_from_url(url)
            img = _sensor_image_from_camera_proto(
                cam_proto, ts_ns, fid, topic=topic, h26x_decoders=h26x_decoders
            )
            if img is not None:
                writer.write(topic, serialize_message(img), ts_ns)
            continue

        if row_kind != 'gpal_proto':
            print(
                f'[skip] Unsupported ser={ser!r} (kind={row_kind!r}) topic={topic}',
                file=sys.stderr,
            )
            continue

        fqn = _proto_fqn_for_url_ser(ser)
        if not fqn:
            print(f'[skip] Unsupported ser={ser!r} topic={topic}', file=sys.stderr)
            continue

        short = _short_name_from_proto_fqn(fqn)
        try:
            proto_cls = _proto_generated_class(pool, fqn)
            ros_cls = _ros_msg_class(short)
        except Exception as exc:  # noqa: BLE001
            print(f'[skip] {fqn}: {exc}', file=sys.stderr)
            continue

        proto_msg = proto_cls()
        try:
            proto_msg.ParseFromString(blob)
        except Exception as exc:  # noqa: BLE001
            print(f'[skip] parse {topic} {fqn}: {exc}', file=sys.stderr)
            continue

        ros_t_computed = _ros_msg_type_string(ros_cls)
        ros_t = exp_ros or ros_t_computed
        if ros_t != ros_t_computed:
            print(
                f'[skip] topic {topic!r}: config ros_type {ros_t!r} != '
                f'expected {ros_t_computed!r} for {fqn}',
                file=sys.stderr,
            )
            continue
        ensure_topic(topic, ros_t)
        ros_msg = ros_cls()
        gpal_conversions.convert(proto_msg, ros_msg)
        writer.write(topic, serialize_message(ros_msg), ts_ns)

    conn.close()
    try:
        writer.close()
    except AttributeError:
        pass


def main() -> int:
    p = argparse.ArgumentParser(description='EkaRT SQLite (.db) to ROS 2 bag (rosbag2).')
    p.add_argument('db', help='Path to EkaRT SQLite database')
    p.add_argument(
        'bag',
        help='Output bag path (directory for sqlite3 storage, or file path for mcap)',
    )
    p.add_argument(
        '--storage',
        default='sqlite3',
        choices=('sqlite3', 'mcap'),
        help='rosbag2 storage backend (default: sqlite3)',
    )
    p.add_argument(
        '--topic-prefix',
        default='',
        help='Optional prefix for every topic (e.g. /vehicle1)',
    )
    p.add_argument(
        '--only-topic',
        action='append',
        dest='only_topics',
        metavar='TOPIC',
        help=(
            'Only write messages for this ROS topic (repeat flag for several). '
            'Names must match db2bag output, e.g. /ekart/shm/hal/compressed/cam_fcf_depth_5. '
            'CameraFrame rows become sensor_msgs/msg/Image (bgr8) with timestamps from the DB. '
            'With --config, narrows the YAML list to this topic (repeatable).'
        ),
    )
    p.add_argument(
        '--config',
        metavar='YAML',
        help=(
            'YAML file (topic, eka_type, ros_type per entry under key "topics"). '
            'Only listed topics are written; eka_type must match EkaRT_Urls.ser, '
            'ros_type must match what db2bag emits for that type.'
        ),
    )
    args = p.parse_args()

    topic_specs: Optional[Dict[str, Tuple[str, str]]] = None
    if args.config:
        topic_specs = _load_db2bag_topic_config(args.config)

    only_set: Optional[FrozenSet[str]] = None
    if args.only_topics:
        only_set = frozenset(_normalize_topic_key(t) for t in args.only_topics)

    pool = _load_descriptor_pool()
    convert_db(
        args.db,
        args.bag,
        args.storage,
        pool,
        topic_prefix=args.topic_prefix,
        only_topics=only_set,
        topic_specs=topic_specs,
    )
    print(f'Wrote bag at {args.bag!r} ({args.storage})')
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
