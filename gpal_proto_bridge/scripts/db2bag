# Generated conversions.py imports e.g. `map_server.foo_pb2`; those modules live under share/.../pb2_py.
_pb2_root = os.path.join(get_package_share_directory('gpal_proto_bridge'), 'pb2_py')
if os.path.isdir(_pb2_root) and _pb2_root not in sys.path:
    sys.path.insert(0, _pb2_root)
try:
    from google.protobuf.descriptor_pb2 import FileDescriptorSet
    from google.protobuf.descriptor_pool import DescriptorPool
except ModuleNotFoundError as exc:
    missing = getattr(exc, 'name', None) or ''
    if not (missing == 'google' or missing.startswith('google.')):
        raise
    raise SystemExit(
        'db2bag needs the Python protobuf module (import google.protobuf).\n'
        'Fix: sudo apt install python3-protobuf   or   pip install protobuf\n'
        'Prefer: source install/setup.bash && ros2 run gpal_proto_bridge db2bag ...\n'
        'so the same environment as rclpy is used (see package.xml exec_depend python3-protobuf).'
    ) from exc

import gpal_proto_bridge.conversions as gpal_conversions

